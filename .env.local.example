# ============================================================
# Hub Match Analyst — variabili d'ambiente locali
# Copia questo file in `.env.local` e riempi i valori reali.
# Trovi tutto in Supabase → Project Settings → API.
# ============================================================

# URL del tuo progetto Supabase (es. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chiave pubblica anonima — usata dal browser. Le RLS proteggono i dati.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chiave amministrativa "service_role" — SOLO server, MAI esposta al client.
# Ci serve per script di amministrazione (es. invito collaboratori, purge cestino).
SUPABASE_SERVICE_ROLE_KEY=
